# ─────────────────────────────────────────────────────────────────────────────
# NexusAI — Environment Variables
# Copy this file to .env.local and fill in every value before running the app.
# Never commit .env.local or any file containing real secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ── App URLs ──────────────────────────────────────────────────────────────────
# Base URL of the Next.js app (no trailing slash).
# In production replace with your actual domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000

# Must match NEXT_PUBLIC_APP_URL exactly — used by NextAuth for OAuth callbacks.
NEXTAUTH_URL=http://localhost:3000


# ── NextAuth ──────────────────────────────────────────────────────────────────
# Random 32-byte hex string.  Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your_nextauth_secret_here


# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must be: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret

# Exposed to the browser — used by AddSourceModal to open the Google Drive picker.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Google API developer key (not OAuth) — needed for the Drive picker widget.
# Create at https://console.cloud.google.com/apis/credentials → API key
NEXT_PUBLIC_DEVELOPPER_KEY=your_google_api_developer_key


# ── MongoDB ───────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (or a local mongod URI for dev).
# The database name is part of the URI path (e.g. /nexusai-db).
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nexusai-db


# ── Pinecone (vector store) ───────────────────────────────────────────────────
# Create an index at https://app.pinecone.io
# Dimension must match the Cohere embedding model output (1024 for embed-english-v3.0).
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=nexusai


# ── LLM providers ─────────────────────────────────────────────────────────────
# Cerebras — used for fast inference (Qwen-3-32B model).
# Get key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-your_cerebras_api_key

# Fireworks AI — used for DeepSeek-V3 (research/complex reasoning tasks).
# Get key at https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=fw_your_fireworks_api_key

# Cohere — used for text embeddings only (embed-english-v3.0).
# Get key at https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key


# ── Exa (web search) ──────────────────────────────────────────────────────────
# Used by the researcher agent to search the web for up-to-date information.
# Get key at https://dashboard.exa.ai
EXA_API_KEY=your_exa_api_key


# ── Cloudinary (media & file uploads) ────────────────────────────────────────
# Create a free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


# ── Real-time collaboration (Yjs / y-websocket) ───────────────────────────────
# WebSocket URL for the y-websocket server (run separately: node scripts/yws-server.mjs).
# In production point this at your deployed WebSocket server.
NEXT_PUBLIC_YWEBSOCKET_URL=ws://localhost:1234

# Optional: port override for the bundled y-websocket server script.
# YWS_PORT=1234
