/public/uploads/
/public/scratchpad/
/public/images/

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
*.pem
.vercel

# ── Test coverage ─────────────────────────────────────────────────────────────
/coverage
