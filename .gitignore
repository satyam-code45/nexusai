# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────────────────────────
/.next/
/out/
/build

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Sensitive / internal docs (never commit) ──────────────────────────────────
